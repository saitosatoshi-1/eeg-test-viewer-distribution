#!/bin/bash
set -euo pipefail
export PYTHONDONTWRITEBYTECODE=1

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SOURCE_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
LOCAL_APP_ROOT="${HOME}/Library/Application Support/EEG Viewer/app"
SHARED_APP_ROOT="/Users/Shared/EEG Viewer/app"

if [ -f "${SOURCE_ROOT}/app.py" ] && [ -d "${SOURCE_ROOT}/static" ]; then
  APP_ROOT="${SOURCE_ROOT}"
elif [ -f "${SHARED_APP_ROOT}/app.py" ] && [ -d "${SHARED_APP_ROOT}/static" ]; then
  APP_ROOT="${SHARED_APP_ROOT}"
elif [ -f "${LOCAL_APP_ROOT}/app.py" ] && [ -d "${LOCAL_APP_ROOT}/static" ]; then
  APP_ROOT="${LOCAL_APP_ROOT}"
else
  APP_ROOT="${SOURCE_ROOT}"
fi

HANDSON_FDS="${HOME}/Desktop/女子医ハンズオン_0606/FDS例"
if [ -d "${HANDSON_FDS}" ]; then
  FDS_LINK="${HOME}/Library/Application Support/EEG Viewer/current_fds"
  mkdir -p "$(dirname "${FDS_LINK}")"
  ln -sfn "${HANDSON_FDS}" "${FDS_LINK}" 2>/dev/null || true
  FDS_DIR="${FDS_LINK}"
elif [ -d "${SOURCE_ROOT}/FDS" ]; then
  FDS_DIR="${SOURCE_ROOT}/FDS"
elif [ -d "/Users/Shared/EEG Viewer/FDS" ]; then
  FDS_DIR="/Users/Shared/EEG Viewer/FDS"
else
  FDS_DIR="${SOURCE_ROOT}/FDS"
fi

RUNTIME_PYTHON="${HOME}/Library/Application Support/EEG Viewer/runtime/bin/python"
DEV_PYTHON="${HOME}/miniforge3/envs/eeg-tn22/bin/python"
SYSTEM_PYTHON="/usr/bin/python3"
SOURCE_INSTALLER="${SOURCE_ROOT}/Install EEG Viewer Runtime.command"
SHARED_INSTALLER="/Users/Shared/EEG Viewer/Install EEG Viewer Runtime.command"

if [ -x "${RUNTIME_PYTHON}" ]; then
  PYTHON="${RUNTIME_PYTHON}"
elif [ -x "${DEV_PYTHON}" ]; then
  PYTHON="${DEV_PYTHON}"
elif [ -x "${SYSTEM_PYTHON}" ]; then
  PYTHON="${SYSTEM_PYTHON}"
else
  PYTHON=""
fi

SERVER_APP="${APP_ROOT}/app.py"

python_can_read_app() {
  local candidate="$1"
  [ -x "${candidate}" ] || return 1
  "${candidate}" -c 'import sys; open(sys.argv[1], "rb").close()' "${SERVER_APP}" >/dev/null 2>&1
}

if [ "${APP_ROOT}" != "${SHARED_APP_ROOT}" ] && [ -f "${SHARED_APP_ROOT}/app.py" ] && [ -d "${SHARED_APP_ROOT}/static" ]; then
  if ! "${RUNTIME_PYTHON}" -c 'import sys; open(sys.argv[1], "rb").close()' "${SERVER_APP}" >/dev/null 2>&1; then
    APP_ROOT="${SHARED_APP_ROOT}"
    SERVER_APP="${APP_ROOT}/app.py"
  fi
fi

if [ -n "${PYTHON}" ] && ! python_can_read_app "${PYTHON}"; then
  if python_can_read_app "${DEV_PYTHON}"; then
    PYTHON="${DEV_PYTHON}"
  elif python_can_read_app "${SYSTEM_PYTHON}"; then
    PYTHON="${SYSTEM_PYTHON}"
  else
    PYTHON=""
  fi
fi

URL="http://127.0.0.1:8765/"
HEALTH_URL="http://127.0.0.1:8765/api/health"
LOG="/private/tmp/eeg_viewer_app.log"
STATE_FILE="/private/tmp/eeg_viewer_app.state"
APP_FINGERPRINT="$(/usr/bin/shasum -a 256 "${APP_ROOT}/app.py" "${APP_ROOT}/static/index.html" "${APP_ROOT}/static/styles.css" "${APP_ROOT}/static/app.js" 2>/dev/null | /usr/bin/shasum -a 256 | /usr/bin/awk '{print $1}' || true)"

show_dialog() {
  /usr/bin/osascript -e "display dialog \"$1\" buttons {\"OK\"} default button \"OK\"" >/dev/null 2>&1 || true
}

shell_quote() {
  local quoted="${1//\'/\'\\\'\'}"
  printf "'%s'" "${quoted}"
}

open_runtime_installer() {
  if [ -f "${SOURCE_INSTALLER}" ]; then
    /usr/bin/open "${SOURCE_INSTALLER}"
  elif [ -f "${SHARED_INSTALLER}" ]; then
    /usr/bin/open "${SHARED_INSTALLER}"
  else
    show_dialog "EEG Viewer Python runtime was not found. Install Miniforge/Conda and run the EEG Viewer runtime installer."
  fi
}

if [ ! -f "${SERVER_APP}" ] || [ ! -d "${APP_ROOT}/static" ]; then
  show_dialog "EEG Viewer app files were not found at ${APP_ROOT}."
  exit 1
fi

if [ -z "${PYTHON}" ] || [ ! -x "${PYTHON}" ]; then
  show_dialog "EEG Viewer Python runtime is not installed yet. The runtime installer will open."
  open_runtime_installer
  exit 0
fi

SERVER_OK=0
HEALTH_PAYLOAD=""
SERVER_FINGERPRINT=""
if HEALTH_PAYLOAD="$(/usr/bin/curl -fsS "${HEALTH_URL}" 2>/dev/null)"; then
  SERVER_OK=1
  SERVER_FINGERPRINT="$(printf '%s' "${HEALTH_PAYLOAD}" | "${PYTHON}" -c 'import json,sys; print(json.load(sys.stdin).get("appFingerprint",""))' 2>/dev/null || true)"
fi

if [ "${SERVER_OK}" -eq 1 ] && [ -n "${APP_FINGERPRINT}" ] && [ -n "${SERVER_FINGERPRINT}" ] && [ "${SERVER_FINGERPRINT}" != "${APP_FINGERPRINT}" ]; then
  echo "Restarting EEG Viewer because the running server is not this app build: ${APP_ROOT}" >> "${LOG}"
  /usr/bin/pkill -f "app.py --no-browser --port 8765" >/dev/null 2>&1 || true
  sleep 0.5
  SERVER_OK=0
fi

if [ "${SERVER_OK}" -eq 0 ]; then
  echo "Starting EEG Viewer from ${APP_ROOT}" >> "${LOG}"
  (
    cd "${APP_ROOT}"
    export PYTHONDONTWRITEBYTECODE=1
    nohup "${PYTHON}" "${SERVER_APP}" --no-browser --port 8765 --fds-dir "${FDS_DIR}" >> "${LOG}" 2>&1 < /dev/null &
    server_pid="$!"
    echo "${server_pid}" > /private/tmp/eeg_viewer_app.pid
    disown "${server_pid}" 2>/dev/null || true
  )

  for _ in $(seq 1 120); do
    if /usr/bin/curl -fsS "${HEALTH_URL}" >/dev/null 2>&1; then
      break
    fi
    sleep 0.25
  done
fi

if /usr/bin/curl -fsS "${HEALTH_URL}" >/dev/null 2>&1; then
  printf '%s\n' "${APP_FINGERPRINT}" > "${STATE_FILE}"
  /usr/bin/open "${URL}"
else
  show_dialog "EEG Viewer could not start. Please check ${LOG}."
  exit 1
fi
